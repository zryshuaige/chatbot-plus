# ===== 大模型 API 配置 =====
# 复制本文件为 .env 并填入真实密钥。.env 不会被提交到 git。
API_KEY=sk-你的密钥
BASE_URL=https://api.siliconflow.cn/v1

# 默认模型（首次新建对话时使用）
DEFAULT_MODEL=deepseek-ai/DeepSeek-V4-Pro

# 可选模型列表（逗号分隔），前端下拉会展示这些
MODELS=deepseek-ai/DeepSeek-V4-Pro,Qwen/Qwen2.5-7B-Instruct,Qwen/Qwen2.5-72B-Instruct,Qwen/Qwen2.5-Coder-32B-Instruct

# 用于“自动命名 / 上下文压缩”的轻量模型（省钱、够用）
UTILITY_MODEL=Qwen/Qwen2.5-7B-Instruct

# ===== 图片生成 / 编辑（专用模型，由对应任务强制使用，与上方 MODELS 无关）=====
# “图片生成”任务使用的文生图模型
IMAGE_GEN_MODEL=Tongyi-MAI/Z-Image-Turbo
# “图片编辑”任务使用的图生图模型
IMAGE_EDIT_MODEL=Qwen/Qwen-Image-Edit-2509
# 生成图片尺寸（如 1024x1024 / 1280x720）
IMAGE_SIZE=1024x1024

# ===== 文档自动生成（Function Calling）=====
# 支持 Function Calling 的模型白名单（逗号分隔）。仅这些模型在对话中注入
# “生成 Word/PPT/Excel”工具——用户说“做个 PPT”“整理成 Word”时模型会自动
# 调用工具生成文件并下发。白名单外模型正常对话、不报错，但不具备文档生成能力。
# 可按你的模型清单自行增删。
FC_MODELS=deepseek-ai/DeepSeek-V4-Pro,deepseek-ai/DeepSeek-V4-Flash,moonshotai/Kimi-K2.7-Code,Pro/moonshotai/Kimi-K2.6,MiniMaxAI/MiniMax-M2.5,Qwen/Qwen2.5-72B-Instruct,Qwen/Qwen2.5-7B-Instruct

# ===== 服务端口 =====
# 后端 FastAPI 端口（避开 project-a 的 8001）
BACKEND_PORT=8002
# 前端 Streamlit 端口
FRONTEND_PORT=8502

# ===== 上下文压缩策略 =====
# 估算 token 超过该阈值时触发对旧消息的摘要压缩
COMPRESS_THRESHOLD=3000
# 压缩时保留最近 N 轮原文（1 轮 = 1 user + 1 assistant）
KEEP_RECENT_TURNS=4

# ===== 文件上传 =====
# 单文件最大体积（MB）
MAX_FILE_SIZE_MB=8
# 单个文本文件抽取正文的最大字符数（超出截断，避免撑爆上下文）
MAX_FILE_CHARS=20000
